---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, lead, align = 'center' } = Astro.props;
---

<header class={`section-header section-header--${align}`} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {lead && <p>{lead}</p>}
</header>

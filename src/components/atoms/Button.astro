---
import { whatsappUrl } from '@utils/whatsapp';

interface Props {
  href?: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'light';
  message?: string;
  class?: string;
}

const {
  href,
  label,
  variant = 'primary',
  message,
  class: className = ''
} = Astro.props;

const finalHref = href ?? whatsappUrl(message);
---

<a class={`button button--${variant} ${className}`} href={finalHref}>
  <span>{label}</span>
  <svg aria-hidden="true" viewBox="0 0 24 24">
    <path d="M5 12h13M13 6l6 6-6 6" />
  </svg>
</a>
